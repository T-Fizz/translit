# Supabase Postgres (optional — service runs without it, using in-memory L2).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Comma-separated bootstrap tenants: "key:tenant-name,key2:tenant-name2".
# Intended for internal use; managed-tenant creation goes through a migration
# into the tenants table (see migrations/001_init.sql).
BOOTSTRAP_API_KEYS=dev-local-key:local

LOG_LEVEL=INFO
MEMO_MAX_ENTRIES=50000
